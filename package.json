{
  "name": "n8n-nodes-wire",
  "version": "0.1.4",
  "description": "n8n community node for Wire. Push entries into a Wire container from any workflow.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "wire",
    "usewire",
    "context",
    "mcp",
    "ai",
    "memory"
  ],
  "license": "MIT",
  "homepage": "https://usewire.io",
  "author": {
    "name": "Wire",
    "email": "support@usewire.io",
    "url": "https://usewire.io"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/usewire/n8n-nodes-wire.git"
  },
  "bugs": {
    "url": "https://github.com/usewire/n8n-nodes-wire/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": false,
    "credentials": [
      "dist/credentials/WireApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Wire/Wire.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.28.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
